{
  "name": "flighttracker",
  "version": "1.0.0",
  "description": "Live-Flugradar mit OpenSky, Typanalyse und Emissionsschaetzung",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host :: --port 6666",
    "build": "vite build",
    "preview": "vite preview --host :: --port 6666",
    "start": "node server/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meinzeug/flighttracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/meinzeug/flighttracker/issues"
  },
  "homepage": "https://github.com/meinzeug/flighttracker#readme",
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "better-sqlite3": "^12.6.2",
    "csv-parse": "^6.1.0",
    "express": "^5.2.1",
    "maplibre-gl": "^5.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "pm2": "^6.0.14",
    "vite": "^6.1.0"
  }
}
